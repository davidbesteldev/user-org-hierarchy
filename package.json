    "prisma:studio": "npx prisma studio",
    "prisma:test:studio": "dotenv -e .env.test -- npx prisma studio --port 51213",
    "test": "jest",
    "pretest:e2e": "dotenv -e .env.test -- prisma migrate reset --force",
    "test:e2e": "dotenv -e .env.test -- jest --runInBand --config jest-e2e.config.ts"
